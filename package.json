{
  "name": "ovijatrik",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npx --yes kill-port 5173 8788 && concurrently --raw \"npm run dev --workspace=frontend\" \"wrangler pages dev frontend/public --port 8788 --compatibility-flag=nodejs_compat\"",
    "dev:full": "npx --yes kill-port 5173 8788 && node Scripts/dev-dashboard.js",
    "build": "npm run build --workspace=frontend",
    "deploy": "npm run build && wrangler pages deploy dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.7.0",
    "wrangler": "^4.103.0"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "drizzle-orm": "^0.45.2"
  }
}
